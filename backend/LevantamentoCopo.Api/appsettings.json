{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=levantamento_copo_db;Username=postgres;Password=YOUR_DB_PASSWORD"
  },
  "AiSettings": {
    "GeminiApiKey": "YOUR_GEMINI_API_KEY_HERE",
